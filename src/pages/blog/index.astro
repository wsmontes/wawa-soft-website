---
import Layout from "../../layouts/Layout.astro";
import { formatBlogDate, getPublishedPosts } from "../../lib/blog";

const posts = await getPublishedPosts();
---

<Layout
  title="Blog"
  description="Notes on independent software, open source, and the work behind Wawasoft products."
  image="/blog-og.png"
>
  <section class="pb-12 pt-16 sm:pt-24">
    <div class="flex items-end justify-between gap-6">
      <div>
        <h1 class="text-[28px] font-medium leading-tight tracking-tight text-[#1a1a1a] sm:text-[32px]">
          Blog
        </h1>
        <p class="mt-3 max-w-[560px] text-[16px] leading-relaxed text-[#5c5c5c]">
          Notes on independent software, open source, and the work behind Wawasoft products.
        </p>
      </div>
      <a
        href="/rss.xml"
        class="mb-0.5 shrink-0 text-[13px] font-medium text-[#6b6b6b] underline decoration-[#c4bfb4] underline-offset-4 transition-colors hover:text-[#1a1a1a] hover:decoration-[#8a8a8a]"
      >
        RSS feed
      </a>
    </div>
  </section>

  <section class="pb-14" aria-label="Blog posts">
    {
      posts.length > 0 ? (
        <div class="divide-y divide-[#e8e4dd] border-y border-[#e8e4dd]">
          {posts.map((post) => (
            <article class="py-6 first:pt-5 last:pb-5">
              <time
                datetime={post.data.publishDate.toISOString()}
                class="font-mono text-[12px] text-[#8a8a8a]"
              >
                {formatBlogDate(post.data.publishDate)}
              </time>
              <h2 class="mt-2 text-[19px] font-medium leading-snug text-[#1a1a1a]">
                <a
                  href={`/blog/${post.id}`}
                  class="decoration-[#c4bfb4] underline-offset-4 transition-colors hover:underline"
                >
                  {post.data.title}
                </a>
              </h2>
              <p class="mt-2 max-w-[620px] text-[15px] leading-relaxed text-[#5c5c5c]">
                {post.data.description}
              </p>
              {post.data.tags.length > 0 && (
                <p class="mt-3 font-mono text-[11px] uppercase tracking-wide text-[#8a8a8a]">
                  {post.data.tags.join(" · ")}
                </p>
              )}
            </article>
          ))}
        </div>
      ) : (
        <p class="text-[15px] leading-relaxed text-[#5c5c5c]">
          The first post is on its way. Subscribe to the RSS feed to follow along.
        </p>
      )
    }
  </section>
</Layout>
