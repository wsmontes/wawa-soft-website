---
import { getCollection, render, type CollectionEntry } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import { formatBlogDate } from "../../lib/blog";

export async function getStaticPaths() {
  const now = new Date();
  const posts = await getCollection(
    "blog",
    ({ data }) => !data.draft && data.publishDate <= now,
  );

  return posts.map((post) => ({
    params: { id: post.id },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Layout
  title={post.data.title}
  description={post.data.description}
  type="article"
  publishedTime={post.data.publishDate}
  image="/blog-og.png"
>
  <article class="pb-16 pt-16 sm:pt-24">
    <header class="max-w-[680px] border-b border-[#e8e4dd] pb-8">
      <a
        href="/blog"
        class="font-mono text-[12px] text-[#8a8a8a] transition-colors hover:text-[#1a1a1a]"
      >
        Blog &larr;
      </a>
      <h1 class="mt-4 text-[30px] font-medium leading-tight tracking-tight text-[#1a1a1a] sm:text-[38px]">
        {post.data.title}
      </h1>
      <p class="mt-4 max-w-[620px] text-[16px] leading-relaxed text-[#5c5c5c]">
        {post.data.description}
      </p>
      <div class="mt-5 flex flex-wrap items-center gap-x-3 gap-y-1 font-mono text-[12px] text-[#8a8a8a]">
        <span>{post.data.author}</span>
        <span aria-hidden="true">&middot;</span>
        <time datetime={post.data.publishDate.toISOString()}>
          {formatBlogDate(post.data.publishDate)}
        </time>
        {
          post.data.updatedDate && (
            <>
              <span aria-hidden="true">&middot;</span>
              <span>Updated {formatBlogDate(post.data.updatedDate)}</span>
            </>
          )
        }
      </div>
    </header>

    <div class="blog-content mt-9 max-w-[680px]">
      <Content />
    </div>

    <footer class="mt-12 flex flex-wrap items-center justify-between gap-4 border-t border-[#e8e4dd] pt-6">
      <a
        href="/blog"
        class="text-[14px] font-medium text-[#1a1a1a] underline decoration-[#c4bfb4] underline-offset-4 transition-colors hover:decoration-[#8a8a8a]"
      >
        &larr; All posts
      </a>
      <a
        href="/rss.xml"
        class="text-[13px] text-[#6b6b6b] underline decoration-[#c4bfb4] underline-offset-4 transition-colors hover:text-[#1a1a1a] hover:decoration-[#8a8a8a]"
      >
        Subscribe via RSS
      </a>
    </footer>
  </article>
</Layout>
