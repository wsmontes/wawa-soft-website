---
import Layout from "../layouts/Layout.astro";
import { site } from "../data/site";
---

<Layout
  title="Contact"
  description={`Get in touch with ${site.founder.name}. Based in ${site.location}.`}
>
  <section class="pb-14 pt-16 sm:pt-24">
    <h1 class="text-[28px] font-medium leading-tight tracking-tight text-[#1a1a1a] sm:text-[32px]">
      Contact
    </h1>
    <p class="mt-3 text-[16px] leading-relaxed text-[#5c5c5c]">
      I'm one person in Victoria, BC. Email is the best way to reach me.
    </p>
  </section>

  <section class="pb-14">
    <div class="space-y-4 max-w-[400px]">
      <div class="flex items-center justify-between rounded-lg border border-[#e8e4dd] px-5 py-3.5">
        <span class="text-[14px] text-[#6b6b6b]">Email</span>
        <a href={`mailto:${site.email}`} class="text-[14px] font-medium text-[#1a1a1a] underline underline-offset-4 decoration-[#c4bfb4] transition-colors hover:decoration-[#8a8a8a]">
          {site.email}
        </a>
      </div>

      <div class="flex items-center justify-between rounded-lg border border-[#e8e4dd] px-5 py-3.5">
        <span class="text-[14px] text-[#6b6b6b]">GitHub</span>
        <a href={site.github} target="_blank" rel="noopener noreferrer" class="text-[14px] font-medium text-[#1a1a1a] underline underline-offset-4 decoration-[#c4bfb4] transition-colors hover:decoration-[#8a8a8a]">
          wsmontes
        </a>
      </div>

      <div class="flex items-center justify-between rounded-lg border border-[#e8e4dd] px-5 py-3.5">
        <span class="text-[14px] text-[#6b6b6b]">LinkedIn</span>
        <a href={site.linkedin} target="_blank" rel="noopener noreferrer" class="text-[14px] font-medium text-[#1a1a1a] underline underline-offset-4 decoration-[#c4bfb4] transition-colors hover:decoration-[#8a8a8a]">
          wsmontes
        </a>
      </div>

      <div class="flex items-center justify-between rounded-lg border border-[#e8e4dd] px-5 py-3.5">
        <span class="text-[14px] text-[#6b6b6b]">Location</span>
        <span class="text-[14px] text-[#1a1a1a]">{site.location}</span>
      </div>
    </div>
  </section>
</Layout>
