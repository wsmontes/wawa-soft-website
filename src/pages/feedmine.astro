---
import Layout from "../layouts/Layout.astro";
import { feedmine, feedmineSections, feedmineStats } from "../data/products";
---

<Layout
  title="Feedmine"
  description={feedmine.description}
>
  <!-- Header -->
  <section class="pb-12 pt-16 sm:pt-24">
    <div class="flex items-center gap-3">
      <img src="/feedmine-symbol.png" alt="" class="h-10 w-10 rounded-md" />
      <p class="font-mono text-[13px] text-[#8a8a8a]">{feedmine.status}</p>
    </div>
    <h1 class="mt-4 text-[28px] font-medium leading-tight tracking-tight text-[#1a1a1a] sm:text-[32px]">
      Feedmine
    </h1>
    <p class="mt-3 max-w-[620px] text-[16px] leading-relaxed text-[#5c5c5c]">
      An open-source, source-first reader for news, podcasts, video, and independent publishing — maintained by Wawasoft, with no accounts and no ads.
    </p>
    <p class="mt-5 max-w-[620px] text-[15px] leading-relaxed text-[#5c5c5c]">
      {feedmine.description}
    </p>
    <div class="mt-8 flex flex-wrap gap-3">
      <a
        href={feedmine.github}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-1.5 rounded-md border border-[#d4d0c8] px-4 py-2 text-[14px] font-medium text-[#1a1a1a] transition-colors hover:border-[#b0aba0] hover:bg-[#f5f3ef]"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
        View repository
      </a>
      <a
        href="/products"
        class="inline-flex items-center gap-1.5 rounded-md border border-[#d4d0c8] px-4 py-2 text-[14px] font-medium text-[#1a1a1a] transition-colors hover:border-[#b0aba0] hover:bg-[#f5f3ef]"
      >
        All products
      </a>
    </div>
  </section>

  <!-- Brand mark -->
  <section class="pb-12">
    <div class="rounded-lg border border-[#e8e4dd] bg-[#fffaf4] p-6">
      <img src="/feedmine-wordmark.png" alt="Feedmine" class="h-auto w-full max-w-[360px]" />
      <div class="mt-6 grid gap-3 sm:grid-cols-2">
        <div class="rounded-md border border-[#f0dfcf] bg-white/60 p-4">
          <p class="font-mono text-[12px] uppercase tracking-wider text-[#8a8a8a]">Mode</p>
          <p class="mt-1 text-[14px] text-[#1a1a1a]">No accounts, no ads, source-first reading.</p>
        </div>
        <div class="rounded-md border border-[#f0dfcf] bg-white/60 p-4">
          <p class="font-mono text-[12px] uppercase tracking-wider text-[#8a8a8a]">Core loop</p>
          <p class="mt-1 text-[14px] text-[#1a1a1a]">Find sources, read calmly, save and export.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="pb-12">
    <h2 class="text-[16px] font-medium text-[#1a1a1a]">Catalog</h2>
    <div class="mt-4 grid gap-3 sm:grid-cols-4">
      {feedmineStats.map((stat) => (
        <div class="rounded-lg border border-[#e8e4dd] p-4">
          <p data-catalog-stat={stat.label} class="text-[22px] font-medium text-[#1a1a1a]" aria-live="polite">{stat.value}</p>
          <p class="mt-1 text-[13px] text-[#6b6b6b]">{stat.label}</p>
        </div>
      ))}
    </div>
  </section>

  <script>
    const manifestUrl = "https://raw.githubusercontent.com/wawasoft/feedmine-repo/main/manifest.json";

    type CatalogManifest = {
      sourceCount?: number;
      fileCount?: number;
      files?: Array<{ path?: string }>;
    };

    async function updateCatalogStats() {
      try {
        const response = await fetch(manifestUrl, { cache: "no-store" });
        if (!response.ok) return;

        const manifest = (await response.json()) as CatalogManifest;
        if (!Array.isArray(manifest.files)) return;

        const countryCount = manifest.files.filter((file) =>
          file.path?.includes("90_countries/")
        ).length;
        const stats: Record<string, string> = {
          Sources: typeof manifest.sourceCount === "number" ? manifest.sourceCount.toLocaleString() : "",
          Countries: countryCount.toString(),
          "OPML files": typeof manifest.fileCount === "number" ? manifest.fileCount.toString() : "",
          Topics: typeof manifest.fileCount === "number" ? (manifest.fileCount - countryCount).toString() : "",
        };

        document.querySelectorAll<HTMLElement>("[data-catalog-stat]").forEach((element) => {
          const value = stats[element.dataset.catalogStat ?? ""];
          if (value) element.textContent = value;
        });
      } catch {
        // Keep the catalog snapshot bundled with the site when GitHub is unavailable.
      }
    }

    void updateCatalogStats();
  </script>

  <!-- Sections -->
  <div class="space-y-10 pb-6">
    {feedmineSections.map((section) => (
      <section>
        <h2 class="text-[16px] font-medium text-[#1a1a1a]">{section.title}</h2>
        <p class="mt-2 max-w-[620px] text-[15px] leading-relaxed text-[#5c5c5c]">
          {section.body}
        </p>
      </section>
    ))}
  </div>

  <!-- Details -->
  <section class="pb-14 pt-6">
    <h2 class="text-[16px] font-medium text-[#1a1a1a]">Details</h2>
    <dl class="mt-3 grid max-w-[520px] gap-3 sm:grid-cols-2">
      <div class="rounded-lg border border-[#e8e4dd] px-5 py-4">
        <dt class="font-mono text-[12px] uppercase tracking-wider text-[#8a8a8a]">Platform</dt>
        <dd class="mt-1 text-[14px] text-[#1a1a1a]">{feedmine.platforms}</dd>
      </div>
      <div class="rounded-lg border border-[#e8e4dd] px-5 py-4">
        <dt class="font-mono text-[12px] uppercase tracking-wider text-[#8a8a8a]">License</dt>
        <dd class="mt-1 text-[14px] text-[#1a1a1a]">{feedmine.license}</dd>
      </div>
      <div class="rounded-lg border border-[#e8e4dd] px-5 py-4">
        <dt class="font-mono text-[12px] uppercase tracking-wider text-[#8a8a8a]">Maintained by</dt>
        <dd class="mt-1 text-[14px] text-[#1a1a1a]">{feedmine.maintainer}</dd>
      </div>
    </dl>
    <div class="mt-5">
      <a
        href={feedmine.github}
        target="_blank"
        rel="noopener noreferrer"
        class="text-[14px] font-medium text-[#1a1a1a] underline underline-offset-4 decoration-[#c4bfb4] transition-colors hover:decoration-[#8a8a8a]"
      >
        Source code (MIT) &rarr;
      </a>
    </div>
  </section>
</Layout>
