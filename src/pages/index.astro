---
import Layout from "../layouts/Layout.astro";
import { site } from "../data/site";
import { wawaNote, principles } from "../data/products";
---

<Layout title={site.name} description={site.description}>
  <!-- Intro -->
  <section class="pb-14 pt-16 sm:pt-24">
    <p class="max-w-[560px] text-[16px] leading-relaxed text-[#5c5c5c]">
      Independent open-source software.<br />
      Built in Victoria, BC.<br />
      A proudly Canadian company.
    </p>
    <div class="mt-8 flex flex-wrap gap-3">
      <a
        href="/wawa-note"
        class="inline-flex items-center gap-1.5 rounded-md border border-[#d4d0c8] px-4 py-2 text-[14px] font-medium text-[#1a1a1a] transition-colors hover:border-[#b0aba0] hover:bg-[#f5f3ef]"
      >
        wawa-note
      </a>
      <a
        href={site.github}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-1.5 rounded-md border border-[#d4d0c8] px-4 py-2 text-[14px] font-medium text-[#1a1a1a] transition-colors hover:border-[#b0aba0] hover:bg-[#f5f3ef]"
      >
        GitHub
      </a>
    </div>
  </section>

  <!-- Current project -->
  <section class="pb-14">
    <h2 class="text-[13px] font-medium uppercase tracking-wider text-[#8a8a8a]">
      Current project
    </h2>
    <div class="mt-4 rounded-lg border border-[#e8e4dd] p-6">
      <h3 class="text-[18px] font-medium text-[#1a1a1a]">
        {wawaNote.name}
      </h3>
      <p class="mt-2 max-w-[560px] text-[15px] leading-relaxed text-[#5c5c5c]">
        {wawaNote.description}
      </p>
      <p class="mt-3 font-mono text-[13px] text-[#8a8a8a]">
        {wawaNote.status}
      </p>
      <div class="mt-5 flex flex-wrap gap-3">
        <a
          href="/wawa-note"
          class="text-[14px] font-medium text-[#1a1a1a] underline underline-offset-4 decoration-[#c4bfb4] transition-colors hover:decoration-[#8a8a8a]"
        >
          Learn more &rarr;
        </a>
        <a
          href={wawaNote.github}
          target="_blank"
          rel="noopener noreferrer"
          class="text-[14px] font-medium text-[#1a1a1a] underline underline-offset-4 decoration-[#c4bfb4] transition-colors hover:decoration-[#8a8a8a]"
        >
          Source code &rarr;
        </a>
      </div>
    </div>
  </section>

  <!-- How I build -->
  <section class="pb-14">
    <h2 class="text-[13px] font-medium uppercase tracking-wider text-[#8a8a8a]">
      How I build software
    </h2>
    <div class="mt-4 grid gap-3 sm:grid-cols-2">
      {principles.map((p) => (
        <div class="rounded-lg border border-[#e8e4dd] p-5">
          <h3 class="text-[15px] font-medium text-[#1a1a1a]">{p.title}</h3>
          <p class="mt-1 text-[14px] leading-relaxed text-[#6b6b6b]">
            {p.detail}
          </p>
        </div>
      ))}
    </div>
  </section>
</Layout>
