---
import Layout from "../layouts/Layout.astro";
import { site } from "../data/site";
import { products, principles } from "../data/products";
---

<Layout title={site.name} description={site.description}>
  <!-- Intro -->
  <section class="pb-14 pt-16 sm:pt-24">
    <p class="max-w-[560px] text-[16px] leading-relaxed text-[#5c5c5c]">
      Independent software.<br />
      Open source when possible.<br />
      A proudly Canadian company.<br />
      Built in Victoria, BC.
    </p>
  </section>

  <!-- Products -->
  <section class="pb-14">
    <h2 class="text-[13px] font-medium uppercase tracking-wider text-[#8a8a8a]">
      Products
    </h2>
    <div class="mt-4 grid gap-3 sm:grid-cols-2">
      {products.map((product) => (
        <article class="rounded-lg border border-[#e8e4dd] p-5">
          <div class="flex items-center gap-3">
            <img src={product.icon} alt="" class="h-8 w-8 shrink-0 rounded-md" />
            <div class="min-w-0">
              <h3 class="text-[17px] font-medium text-[#1a1a1a]">{product.name}</h3>
              <p class="mt-0.5 font-mono text-[12px] text-[#8a8a8a]">
                {product.status}
              </p>
            </div>
          </div>
          <p class="mt-3 text-[14px] leading-relaxed text-[#5c5c5c]">
            {product.summary}
          </p>
          <div class="mt-4 flex flex-wrap gap-3">
            <a
              href={product.href}
              class="text-[14px] font-medium text-[#1a1a1a] underline underline-offset-4 decoration-[#c4bfb4] transition-colors hover:decoration-[#8a8a8a]"
            >
              Learn more &rarr;
            </a>
            <a
              href={product.github}
              target="_blank"
              rel="noopener noreferrer"
              class="text-[14px] font-medium text-[#1a1a1a] underline underline-offset-4 decoration-[#c4bfb4] transition-colors hover:decoration-[#8a8a8a]"
            >
              Repository &rarr;
            </a>
          </div>
        </article>
      ))}
    </div>
  </section>

  <!-- How I build -->
  <section class="pb-14">
    <h2 class="text-[13px] font-medium uppercase tracking-wider text-[#8a8a8a]">
      How I build software
    </h2>
    <div class="mt-4 grid gap-3 sm:grid-cols-2">
      {principles.map((p) => (
        <div class="rounded-lg border border-[#e8e4dd] p-5">
          <h3 class="text-[15px] font-medium text-[#1a1a1a]">{p.title}</h3>
          <p class="mt-1 text-[14px] leading-relaxed text-[#6b6b6b]">
            {p.detail}
          </p>
        </div>
      ))}
    </div>
  </section>
</Layout>
