---
import Layout from "../layouts/Layout.astro";
import { products } from "../data/products";
---

<Layout
  title="Products"
  description="Products built by Wawasoft."
>
  <section class="pb-14 pt-16 sm:pt-24">
    <h1 class="text-[28px] font-medium leading-tight tracking-tight text-[#1a1a1a] sm:text-[32px]">
      Products
    </h1>
    <p class="mt-3 max-w-[560px] text-[16px] leading-relaxed text-[#5c5c5c]">
      Small, opinionated tools for personal knowledge, reading, and independent work.
    </p>
  </section>

  <section class="pb-14">
    <div class="grid gap-4">
      {products.map((product) => (
        <article class="rounded-lg border border-[#e8e4dd] p-6">
          <div class="flex items-start gap-4">
            <img src={product.icon} alt="" class="mt-1 h-10 w-10 shrink-0 rounded-md" />
            <div class="min-w-0 flex-1">
              <h2 class="text-[18px] font-medium text-[#1a1a1a]">{product.name}</h2>
              <p class="mt-1 font-mono text-[12px] text-[#8a8a8a]">{product.status}</p>
              <p class="mt-3 max-w-[560px] text-[15px] leading-relaxed text-[#5c5c5c]">
                {product.summary}
              </p>
              <div class="mt-4 flex flex-wrap gap-x-6 gap-y-2 text-[13px] text-[#6b6b6b]">
                <p>
                  <span class="font-mono uppercase tracking-wider text-[#8a8a8a]">Platform</span>
                  <span class="ml-2 text-[#1a1a1a]">{product.platforms}</span>
                </p>
                <p>
                  <span class="font-mono uppercase tracking-wider text-[#8a8a8a]">License</span>
                  <span class="ml-2 text-[#1a1a1a]">{product.license}</span>
                </p>
              </div>
            </div>
          </div>
          <div class="mt-5 flex flex-wrap gap-3 sm:pl-14">
            <a
              href={product.href}
              class="text-[14px] font-medium text-[#1a1a1a] underline underline-offset-4 decoration-[#c4bfb4] transition-colors hover:decoration-[#8a8a8a]"
            >
              Learn more &rarr;
            </a>
            <a
              href={product.github}
              target="_blank"
              rel="noopener noreferrer"
              class="text-[14px] font-medium text-[#1a1a1a] underline underline-offset-4 decoration-[#c4bfb4] transition-colors hover:decoration-[#8a8a8a]"
            >
              Repository &rarr;
            </a>
          </div>
        </article>
      ))}
    </div>
  </section>
</Layout>
