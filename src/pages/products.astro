---
import Layout from "../layouts/Layout.astro";
import { wawaNote } from "../data/products";
---

<Layout
  title="wawa-note"
  description="The first Wawasoft project. An open-source workspace for notes, meetings, and project knowledge."
>
  <section class="pb-14 pt-16 sm:pt-24">
    <h1 class="text-[28px] font-medium leading-tight tracking-tight text-[#1a1a1a] sm:text-[32px]">
      wawa-note
    </h1>
    <p class="mt-3 text-[16px] leading-relaxed text-[#5c5c5c]">
      The first Wawasoft project. More tools will be added here as they're built.
    </p>
  </section>

  <section class="pb-14">
    <div class="rounded-lg border border-[#e8e4dd] p-6">
      <div class="flex items-center gap-3">
        <h2 class="text-[18px] font-medium text-[#1a1a1a]">{wawaNote.name}</h2>
        <span class="rounded-full bg-[#f0ede7] px-2.5 py-0.5 font-mono text-[11px] text-[#6b6b6b]">
          active
        </span>
      </div>
      <p class="mt-2 max-w-[560px] text-[15px] leading-relaxed text-[#5c5c5c]">
        {wawaNote.description}
      </p>
      <div class="mt-5 flex flex-wrap gap-3">
        <a
          href="/wawa-note"
          class="text-[14px] font-medium text-[#1a1a1a] underline underline-offset-4 decoration-[#c4bfb4] transition-colors hover:decoration-[#8a8a8a]"
        >
          Learn more &rarr;
        </a>
        <a
          href={wawaNote.github}
          target="_blank"
          rel="noopener noreferrer"
          class="text-[14px] font-medium text-[#1a1a1a] underline underline-offset-4 decoration-[#c4bfb4] transition-colors hover:decoration-[#8a8a8a]"
        >
          Source code &rarr;
        </a>
      </div>
    </div>
  </section>
</Layout>
