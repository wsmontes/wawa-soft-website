---
export interface Props {
  label?: string;
  title: string;
  description?: string;
  align?: "left" | "center";
}
const { label, title, description, align = "center" } = Astro.props;
---

<div class={`max-w-2xl ${align === "center" ? "mx-auto text-center" : ""}`}>
  {label && (
    <p class="mb-3 text-sm font-medium text-warm-600">{label}</p>
  )}
  <h2 class="text-3xl font-bold tracking-tight text-ink-900 sm:text-4xl">
    {title}
  </h2>
  {description && (
    <p class="mt-4 text-lg leading-relaxed text-ink-500">{description}</p>
  )}
</div>
