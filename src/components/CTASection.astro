---
import Button from "./Button.astro";

export interface Props {
  title: string;
  description?: string;
  primaryLabel: string;
  primaryHref: string;
  secondaryLabel?: string;
  secondaryHref?: string;
}
const { title, description, primaryLabel, primaryHref, secondaryLabel, secondaryHref } = Astro.props;
---

<div class="rounded-2xl border border-ink-100 bg-warm-50 px-8 py-12 text-center">
  <h2 class="text-2xl font-bold tracking-tight text-ink-900 sm:text-3xl">{title}</h2>
  {description && (
    <p class="mx-auto mt-3 max-w-xl text-base leading-relaxed text-ink-500">{description}</p>
  )}
  <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
    <Button href={primaryHref} variant="primary">{primaryLabel}</Button>
    {secondaryLabel && secondaryHref && (
      <Button href={secondaryHref} variant="outline">{secondaryLabel}</Button>
    )}
  </div>
</div>
